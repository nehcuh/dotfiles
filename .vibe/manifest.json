  "security": {
    "severity_levels": {
      "P0": {
        "label": "block",
        "meaning": "Clear malicious intent or unacceptable unsafe execution chain.",
        "runtime_action": "deny_and_stop",
        "examples": [
          "Secrets or project contents prepared for exfiltration",
          "Destructive or irreversible operations without explicit authorization",
          "Instructions to bypass approvals, safety controls, or audit"
        ]
      },
      "P1": {
        "label": "high_risk_review",
        "meaning": "Potentially legitimate action that requires context review or explicit approval.",
        "runtime_action": "require_context_review_or_user_confirmation",
        "examples": [
          "Network calls that might send code or data outward",
          "Auth, credential, permission, or signing flows",
          "Dynamic execution or remote script execution"
        ]
      },
      "P2": {
        "label": "warning",
        "meaning": "Suspicious or incomplete signal that should be surfaced but not blocked by default.",
        "runtime_action": "warn_log_continue",
        "examples": [
          "Compliance-style persuasion language",
          "Vague backup, sync, or export instructions",
          "Ambiguous archive or upload steps without sensitive context"
        ]
      }
    },

# Secrets template — copy to ~/.config/zsh/secrets.zsh and fill in real values.
# ~/.config/zsh/secrets.zsh is NOT tracked by git.

# OpenAI-compatible API (e.g. z.ai, OpenAI, etc.)
# export OPENAI_BASE_URL="https://api.openai.com/v1"
# export OPENAI_API_KEY="your-key-here"

# LLM key (for Neovim AI plugins)
# export LLM_KEY="your-key-here"

# KIMI Coding Plan
export KIMI_API_KEY=[REDACTED]

# ZAI Coding Plan
export ZAI_API_KEY=[REDACTED]

# Discord bot token
# export DISCORD_BOT_TOKEN="your-token-here"

# Go proxy (uncomment if you need China mirror)
# export GOPROXY=https://goproxy.io,direct

# Git config
[credential]
	helper = !gh auth git-credential
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential

# Local overrides (user identity, signing key, etc.) — not tracked by git
[include]
	path = ~/.gitconfig_local

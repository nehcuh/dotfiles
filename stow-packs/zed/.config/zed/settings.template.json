{
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": false,
      "provider": "ZAI",
      "model": "glm-4.7"
    },
    "model_parameters": []
  },
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "settings": {
        "github_personal_access_token": "YOUR_GITHUB_PAT_HERE"
      }
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "YOUR_CONTEXT7_API_KEY_HERE"
      }
    }
  },
  "language_models": {
    "openai_compatible": {
      "Volcengine": {
        "api_url": "https://ark.cn-beijing.volces.com/api/coding/v3",
        "available_models": [
          {
            "name": "kimi-k2.5",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          },
          {
            "name": "glm-4.7",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          },
          {
            "name": "deepseek-v3.2",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          }
        ]
      },
      "ZAI": {
        "api_url": "https://open.bigmodel.cn/api/coding/paas/v4",
        "available_models": [
          {
            "name": "glm-4.7",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false
            }
          }
        ]
      }
    }
  },
  "ui_font_size": 16,
  "buffer_font_family": "Fira Code",
  "buffer_font_size": 14,
  "buffer_line_height": "comfortable",
  "tab_size": 2,
  "soft_wrap": "editor_width",
  "show_whitespaces": "selection",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "theme": "Catppuccin Mocha",
  "vim_mode": true,
  "terminal": {
    "shell": {
      "program": "zsh"
    },
    "font_family": "Hack Nerd Font Propo",
    "font_size": 14,
    "font_weight": 400
  },
  "git": {
    "inline_blame": {
      "enabled": true
    },
    "git_gutter": "tracked_files"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
